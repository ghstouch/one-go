# OmniRoute Go - Environment Configuration

# Server Configuration
SERVER_PORT=8080
SERVER_HOST=0.0.0.0
GIN_MODE=debug

# Database Configuration
# Options: sqlite, postgres
DB_DRIVER=sqlite

# SQLite Configuration (used when DB_DRIVER=sqlite)
SQLITE_PATH=./storage/omniroute.db

# PostgreSQL Configuration (used when DB_DRIVER=postgres)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=omniroute
POSTGRES_PASSWORD=omniroute
POSTGRES_DB=omniroute
POSTGRES_SSLMODE=disable

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRY_HOURS=24
JWT_ISSUER=omniroute-go

# Admin Configuration
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Logging Configuration
LOG_LEVEL=debug
LOG_FORMAT=console

# Security
STORAGE_ENCRYPTION_KEY=your-32-byte-encryption-key-here

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# CORS
CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-API-Key
